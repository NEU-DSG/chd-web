---
pagination:
    data: rdf
    size: 1
    alias: organizations
permalink: en/organizations/{{ organizations.organization.value | lastSegment }}/index.html
---
<h1> {{ organizations.organizationLabel.value }}</h1>
<h3> {{ organizations.description.value}} </h3>

<dl>
{% set skip = "organization,organizationLabel,description" %}
{%- for key, value in organizations %}
  {% if key not in skip %}
  <dt><strong>{{ key | changeCase }}</strong></dt>
  <dd>
  {%- if key == "organization_type" or key == "neighborhood" or key == "country" %}
    <a href="/en/terms/{{ value.value | lastSegment }}">{{ value.value | labelFromUrl | capitalize }}</a>
  {%- elif key == "official_website" %}
    <a href="{{ value.value }}" target="_blank">{{ value.value }}</a>
  {%- elif key == "records_creator_for"%}
    <a href="/en/collections/{{ value.value | lastSegment }}">{{ value.value | labelFromUrl}}</a>
  {%- else%}
    {{ value.value }}
  {% endif %}
  </dd>
  {% endif %}
{%- endfor %}
</dl>


