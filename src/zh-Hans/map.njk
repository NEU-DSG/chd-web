---
layout: base.njk
data: organizationsZhHans
---

{% block head %}
	<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>
	<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
	<style>
		.leaflet-container {
			height: 600px;
			width: 800px;
			max-width: 100%;
			margin: 0 auto;
		}
        .leaflet-popup-content strong {
            color: #333 !important;
        }
	</style>
{% endblock %}

<h1 style="text-align: center;">组织</h1>
<div id="map"></div>

<script>
	const map = L.map('map').setView([42.35, -71.08], 11);

	const tiles = L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
		maxZoom: 19,
		attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
	}).addTo(map);

	const organizations = {{ organizationsZhHans | dump | safe }};

	organizations.forEach(loc => {
		const coordStr = loc.coordinate_location?.value;
		if (!coordStr) return;
		const [lat, lng] = coordStr.split(",").map(Number);
		L.marker([lat, lng])
			.addTo(map)
			.bindPopup(`<strong><a href="/zh-Hans/organizations/${ loc.organization.value.split('/').pop() }">${loc.organizationLabel.value}</a></strong>`);
	});
</script>