---
pagination:
    data: rdfZhHant
    size: 1
    alias: organizations
permalink: zh-Hant/organizations/{{ organizations.organization.value | lastSegment }}/index.html
---
<h1> {{ organizations.organizationLabel.value }}</h1>
<em>組織</em>
<h3> {{ organizations.description.value}} </h3>
<dl>
{% set skip = "organization,organizationLabel,description" %}
{%- for key, value in organizations %}
  {# organization, organizationLabel and description are already displayed#}
  {% if key not in skip %}
  {# Labels #}
  {# Displaying the zh-Hant labels. Because the properties are pluralized in the SPARQL query, we need to un-pluralize them 
   in order to get the zh-Hant labels from the index. Index retrieved from propertySwitcher.js file#}
  {% if key == "records_creator_for_list" or key == "maintainer_of_list" or key == "donor_for_list" or key == "founders" %}
    <dt><strong>{{ propertySwitcher[key | makeSingular].zhhant }}</strong></dt>
  {% else %}
    <dt><strong>{{ propertySwitcher[key].zhhant }}</strong></dt>
  {% endif%}

  {# Data Fields #}
  <dd>
  {# Terms #}
  {%- if key == "organization_type" or key == "location" or key == "country" %}
    <a href="/zh-Hant/terms/{{ value.value | lastSegment }}">{{ termSwitcher[value.value | lastSegment].zhhant }}</a>
  {# Website #}
  {%- elif key == "official_website" %}
    <a href="{{ value.value }}" target="_blank">{{ value.value }}</a>
  {# Founders #}
  {%- elif key == "founders" %}
    {% for item in value.value.split("|") %}
      <a href="/zh-Hant/people/{{ item | lastSegment }}">{{ item | labelFromUrl}}</a><br>
    {% endfor %}
  {# Other Linked Records #}
  {%- elif key == "records_creator_for_list" or key == "maintainer_of_list" or key == "donor_for_list" %}
    {% for item in value.value.split("|") %}
      <a href="/zh-Hant/collections/{{ item | lastSegment }}">{{ collectionSwitcher[item | lastSegment].zhhant}}</a><br>
    {% endfor %}
  {%- else%}
    {{ value.value }}
  {% endif %}
  </dd>
  {% endif %}
{%- endfor %}
</dl>
